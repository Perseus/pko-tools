   120	/// The net effect is that the high 5 bits are blue and the low 5 bits are red.
   121	pub fn rgb565_to_float(color: i16) -> (f32, f32, f32) {
   122	    let c = color as u16;
   123	    // High 5 bits = blue, middle 6 bits = green, low 5 bits = red
   124	    let b = ((c & 0xf800) >> 8) as f32 / 255.0;
   125	    let g = ((c & 0x07e0) >> 3) as f32 / 255.0;
   126	    let r = ((c & 0x001f) << 3) as f32 / 255.0;
   127	    (r, g, b)
   128	}
